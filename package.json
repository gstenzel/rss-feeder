{
	"name": "rss-watcher-cli",
	"version": "1.0.4",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/gstenzel/rss-feeder.git"
	},
	"files": [
		"src"
	],
	"bin": "./dist/index.js",
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"@libsql/client": "^0.17.3",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"cac": "^7.0.0",
		"dotenv": "^17.4.2",
		"drizzle-orm": "^0.45.2",
		"rss-parser": "^3.13.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.14",
		"@types/bun": "^1.3.13",
		"drizzle-kit": "^0.31.10",
		"tsx": "^4.21.0"
	},
	"scripts": {
		"db:generate": "drizzle-kit generate",
		"check": "bunx --bun @biomejs/biome check --write && bun tsc --noEmit && echo 'all checks passed'",
		"cli": "bun run src/index.ts",
		"mcp": "bun run src/index.ts mcp",
		"release": "npm version patch && git push --follow-tags",
		"test": "bun test",
		"build": "bun build ./src/index.ts --target node --format esm --packages external --outfile ./dist/index.js --banner '#!/usr/bin/env node'",
		"prepack": "bun run build"
	},
	"module": "src/index.ts",
	"type": "module",
	"peerDependencies": {
		"typescript": "^5.9.3"
	}
}
